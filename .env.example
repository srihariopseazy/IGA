# ============================================================
# IGA Platform - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
#
# Generate secrets with:
#   python -c "import secrets; print(secrets.token_hex(32))"
#   openssl rand -base64 32
# ============================================================

# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME=IGA Platform
APP_VERSION=1.0.0

# Set to false in production
DEBUG=false

# production | staging | development | testing
ENVIRONMENT=production

# 256-bit hex secret (64 hex chars) — used for signing cookies, CSRF tokens
SECRET_KEY=change-me-to-a-256-bit-hex-secret-key-generated-with-openssl

# 32-byte base64 key used for field-level encryption of sensitive data
# Generate: python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEY=change-me-to-a-32-byte-base64-encoded-encryption-key

# JWT signing secret — separate from SECRET_KEY for rotation isolation
JWT_SECRET_KEY=change-me-to-a-different-256-bit-jwt-secret

# JWT algorithm (HS256 | RS256 | ES256)
JWT_ALGORITHM=HS256

# Access token expiry in minutes
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Refresh token expiry in days
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# API version prefix
API_V1_PREFIX=/api/v1

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=https://iga.example.com,https://admin.iga.example.com

# Trusted hosts (comma-separated) for Host header validation
ALLOWED_HOSTS=iga.example.com,admin.iga.example.com,localhost

# Backend public URL (used for building callback/redirect URLs)
BACKEND_URL=https://iga.example.com

# Frontend public URL
FRONTEND_URL=https://iga.example.com

# ─── Database (PostgreSQL) ───────────────────────────────────────────────────
# Full async-compatible DSN
DATABASE_URL=postgresql+asyncpg://iga_user:iga_password@postgres:5432/iga_db

# Synchronous DSN for Alembic migrations
SYNC_DATABASE_URL=postgresql://iga_user:iga_password@postgres:5432/iga_db

# PostgreSQL direct credentials (used by docker-compose)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=iga_db
POSTGRES_USER=iga_user
POSTGRES_PASSWORD=change-me-strong-postgres-password

# Connection pool settings
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800

# ─── Redis ────────────────────────────────────────────────────────────────────
# Main Redis URL (DB 0 for general cache)
REDIS_URL=redis://:redis_password@redis:6379/0

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me-strong-redis-password

# Redis DB assignments
REDIS_DB_CACHE=0
REDIS_DB_SESSIONS=1
REDIS_DB_RATE_LIMIT=2
REDIS_DB_CELERY_RESULTS=3

# Session TTL in seconds (default 3600 = 1 hour)
SESSION_TTL_SECONDS=3600

# ─── RabbitMQ / Celery ────────────────────────────────────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=iga_user
RABBITMQ_PASSWORD=change-me-strong-rabbitmq-password
RABBITMQ_VHOST=iga_vhost
RABBITMQ_ERLANG_COOKIE=change-me-random-erlang-cookie
RABBITMQ_URL=amqp://iga_user:change-me-strong-rabbitmq-password@rabbitmq:5672/iga_vhost

# Celery broker and result backend
CELERY_BROKER_URL=amqp://iga_user:change-me-strong-rabbitmq-password@rabbitmq:5672/iga_vhost
CELERY_RESULT_BACKEND=redis://:redis_password@redis:6379/3

# Celery concurrency per worker process
CELERY_WORKER_CONCURRENCY=4

# Task time limits (seconds)
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_TASK_TIME_LIMIT=600

# ─── Flower (Celery UI) ───────────────────────────────────────────────────────
FLOWER_PORT=5555
FLOWER_USER=admin
FLOWER_PASSWORD=change-me-flower-password

# ─── Email / SMTP ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=iga-noreply@example.com
SMTP_PASSWORD=change-me-smtp-password
SMTP_USE_TLS=true
SMTP_USE_SSL=false
EMAIL_FROM_ADDRESS=iga-noreply@example.com
EMAIL_FROM_NAME=IGA Platform

# ─── MinIO (Object Storage) ───────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=change-me-minio-access-key
MINIO_SECRET_KEY=change-me-minio-secret-key
MINIO_SECURE=false
MINIO_BUCKET_REPORTS=iga-reports
MINIO_BUCKET_AVATARS=iga-avatars
MINIO_BUCKET_EXPORTS=iga-exports
MINIO_BUCKET_IMPORTS=iga-imports
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=change-me-minio-root-password
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BROWSER_REDIRECT_URL=https://iga.example.com/minio

# ─── LDAP / Active Directory ─────────────────────────────────────────────────
LDAP_ENABLED=false
LDAP_SERVER=ldap://ad.example.com:389
LDAP_USE_SSL=false
LDAP_USE_TLS=true
LDAP_BIND_DN=CN=iga-svc,OU=ServiceAccounts,DC=example,DC=com
LDAP_BIND_PASSWORD=change-me-ldap-bind-password
LDAP_BASE_DN=DC=example,DC=com
LDAP_USER_SEARCH_BASE=OU=Users,DC=example,DC=com
LDAP_GROUP_SEARCH_BASE=OU=Groups,DC=example,DC=com
LDAP_USER_FILTER=(objectClass=person)
LDAP_GROUP_FILTER=(objectClass=group)
LDAP_USER_OBJECT_CLASS=person
LDAP_GROUP_OBJECT_CLASS=group
LDAP_USER_ID_ATTR=sAMAccountName
LDAP_USER_EMAIL_ATTR=mail
LDAP_USER_FIRSTNAME_ATTR=givenName
LDAP_USER_LASTNAME_ATTR=sn
LDAP_USER_DISPLAY_NAME_ATTR=displayName
LDAP_GROUP_MEMBER_ATTR=member
LDAP_SYNC_INTERVAL_MINUTES=60
LDAP_CONNECTION_TIMEOUT=10
LDAP_PAGE_SIZE=500

# ─── SAML 2.0 ────────────────────────────────────────────────────────────────
SAML_ENABLED=false
SAML_SP_ENTITY_ID=https://iga.example.com/saml/metadata
SAML_SP_ACS_URL=https://iga.example.com/api/v1/auth/saml/acs
SAML_SP_SLS_URL=https://iga.example.com/api/v1/auth/saml/sls
SAML_SP_CERT_FILE=/app/certs/sp.crt
SAML_SP_KEY_FILE=/app/certs/sp.key
SAML_IDP_ENTITY_ID=https://idp.example.com/saml/metadata
SAML_IDP_SSO_URL=https://idp.example.com/saml/sso
SAML_IDP_SLO_URL=https://idp.example.com/saml/slo
SAML_IDP_CERT=MIIC...change-me...
SAML_SIGN_REQUESTS=true
SAML_WANT_ASSERTIONS_SIGNED=true
SAML_WANT_RESPONSE_SIGNED=true
SAML_NAME_ID_FORMAT=urn:oasis:names:tc:SAML:2.0:nameid-format:persistent

# ─── OAuth 2.0 / OIDC ────────────────────────────────────────────────────────
OAUTH_ENABLED=false

# Microsoft Entra ID / Azure AD
AZURE_AD_ENABLED=false
AZURE_AD_TENANT_ID=change-me-azure-tenant-id
AZURE_AD_CLIENT_ID=change-me-azure-client-id
AZURE_AD_CLIENT_SECRET=change-me-azure-client-secret
AZURE_AD_AUTHORITY=https://login.microsoftonline.com/change-me-tenant-id

# Google OAuth
GOOGLE_OAUTH_ENABLED=false
GOOGLE_CLIENT_ID=change-me-google-client-id
GOOGLE_CLIENT_SECRET=change-me-google-client-secret

# OIDC generic provider
OIDC_ENABLED=false
OIDC_DISCOVERY_URL=https://idp.example.com/.well-known/openid-configuration
OIDC_CLIENT_ID=change-me-oidc-client-id
OIDC_CLIENT_SECRET=change-me-oidc-client-secret
OIDC_REDIRECT_URI=https://iga.example.com/api/v1/auth/oidc/callback

# ─── MFA / TOTP ───────────────────────────────────────────────────────────────
MFA_ENABLED=true
MFA_ISSUER=IGA Platform
MFA_TOTP_PERIOD=30
MFA_TOTP_DIGITS=6
MFA_BACKUP_CODE_COUNT=10
WEBAUTHN_RP_ID=iga.example.com
WEBAUTHN_RP_NAME=IGA Platform
WEBAUTHN_ORIGIN=https://iga.example.com

# ─── OpenPolicyAgent (OPA) ───────────────────────────────────────────────────
OPA_ENABLED=true
OPA_URL=http://opa:8181
OPA_POLICY_PATH=iga/authz
OPA_TIMEOUT_SECONDS=5

# ─── AI / Risk Scoring ───────────────────────────────────────────────────────
# Enable ML-based risk scoring
ML_RISK_SCORING_ENABLED=true

# Anomaly detection sensitivity (0.0 - 1.0, higher = more sensitive)
ANOMALY_DETECTION_SENSITIVITY=0.7

# Risk score thresholds (0-100)
RISK_SCORE_LOW_THRESHOLD=30
RISK_SCORE_MEDIUM_THRESHOLD=60
RISK_SCORE_HIGH_THRESHOLD=80
RISK_SCORE_CRITICAL_THRESHOLD=90

# Model retraining schedule (cron format)
RISK_MODEL_RETRAIN_SCHEDULE=0 2 * * 0

# ─── Provisioning ─────────────────────────────────────────────────────────────
# Maximum concurrent provisioning tasks per tenant
MAX_CONCURRENT_PROVISIONING=10

# Provisioning retry attempts on failure
PROVISIONING_RETRY_ATTEMPTS=3

# Delay between retries (seconds)
PROVISIONING_RETRY_DELAY=60

# Default provisioning timeout (seconds)
PROVISIONING_TASK_TIMEOUT=300

# ─── Certification Campaigns ─────────────────────────────────────────────────
# Maximum items per certification batch
CERTIFICATION_BATCH_SIZE=100

# Days before certification expiry to send reminder
CERTIFICATION_REMINDER_DAYS=7

# Auto-revoke uncertified access after N days past deadline
CERTIFICATION_AUTO_REVOKE_DAYS=0

# ─── SoD (Segregation of Duties) ─────────────────────────────────────────────
# Enable real-time SoD checking on access requests
SOD_REALTIME_CHECK_ENABLED=true

# Maximum SoD violations before blocking request
SOD_MAX_VIOLATIONS_BEFORE_BLOCK=0

# ─── Password Policy ─────────────────────────────────────────────────────────
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGITS=true
PASSWORD_REQUIRE_SPECIAL=true
PASSWORD_HISTORY_COUNT=10
PASSWORD_EXPIRY_DAYS=90
PASSWORD_LOCKOUT_ATTEMPTS=5
PASSWORD_LOCKOUT_DURATION_MINUTES=30

# ─── Audit Log ───────────────────────────────────────────────────────────────
AUDIT_LOG_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=2555
# Elasticsearch index pattern for audit logs
AUDIT_LOG_ES_INDEX=iga-audit

# ─── Elasticsearch / Kibana ──────────────────────────────────────────────────
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=change-me-elasticsearch-password
KIBANA_PORT=5601
KIBANA_SYSTEM_PASSWORD=change-me-kibana-password
LOGSTASH_INTERNAL_PASSWORD=change-me-logstash-password

# ─── Monitoring / Observability ──────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password
GRAFANA_ROOT_URL=https://iga.example.com/grafana

# OpenTelemetry
OTEL_ENABLED=false
OTEL_SERVICE_NAME=iga-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=0.1

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
# Requests per minute for API endpoints
RATE_LIMIT_PER_MINUTE=100
# Requests per minute for auth endpoints
RATE_LIMIT_AUTH_PER_MINUTE=10
# Requests per minute for SCIM endpoints
RATE_LIMIT_SCIM_PER_MINUTE=60

# ─── Feature Flags ────────────────────────────────────────────────────────────
FEATURE_GRAPHQL_ENABLED=true
FEATURE_SCIM_ENABLED=true
FEATURE_WEBHOOKS_ENABLED=true
FEATURE_WORKFLOW_ENABLED=true
FEATURE_AI_INSIGHTS_ENABLED=true
FEATURE_SELF_SERVICE_ENABLED=true
FEATURE_DELEGATION_ENABLED=true
FEATURE_GUEST_USERS_ENABLED=false

# ─── Multi-tenancy ───────────────────────────────────────────────────────────
# Default tenant slug for single-tenant deployments
DEFAULT_TENANT_SLUG=default

# Maximum tenants per deployment (0 = unlimited)
MAX_TENANTS=0

# Maximum users per tenant (0 = unlimited)
MAX_USERS_PER_TENANT=0

# ─── Nginx ────────────────────────────────────────────────────────────────────
NGINX_SERVER_NAME=iga.example.com
NGINX_SSL_CERT=/etc/nginx/certs/fullchain.pem
NGINX_SSL_KEY=/etc/nginx/certs/privkey.pem
BACKEND_PORT=8000

# ─── Sentry (optional error tracking) ───────────────────────────────────────
SENTRY_ENABLED=false
SENTRY_DSN=https://change-me@sentry.example.com/1
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
