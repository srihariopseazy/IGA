  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(up{job=\"iga-backend\"}, instance)",
        "hide": 0,
        "includeAll": true,
